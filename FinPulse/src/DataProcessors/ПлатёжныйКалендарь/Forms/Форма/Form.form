    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	Документ.Дата КАК Дата,
	Документ.СтатьяДДС КАК СтатьяДДС,
	Документ.Сумма КАК Сумма,
	Документ.Статус КАК Статус
ИЗ
	Документ.Документ КАК Документ
ГДЕ
	Документ.Дата &lt; &amp;Сегодня
	И Документ.Статус = ЗНАЧЕНИЕ(Перечисление.Статус.План)</queryText>
      <mainTable>Document.Документ</mainTable>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Дата</dataPath>
        <field>Дата</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>СтатьяДДС</dataPath>
        <field>СтатьяДДС</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Сумма</dataPath>
        <field>Сумма</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Статус</dataPath>
        <field>Статус</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Номер</dataPath>
        <field>Номер</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Валюта</dataPath>
        <field>Валюта</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Контрагент</dataPath>
        <field>Контрагент</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Счёт</dataPath>
        <field>Счёт</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>СчётПолучателя</dataPath>
        <field>СчётПолучателя</field>
      </fields>
