#Область ПрограммныйИнтерфейс

// Получает описание товара из Mistral
//
// Параметры:
//  ПлатёжныйКалендарь - Строка - название товара, для которого нужно получить описание
//
// Возвращаемое значение:
//  Строка - описание товара
Асинх Функция ПолучитьАналитику(ПлатёжныйКалендарь) Экспорт

	Если ПустаяСтрока(ПлатёжныйКалендарь) Тогда
		Возврат "";
	КонецЕсли;
 
	APIКлюч = "I9aTrNTwYgYIeWQTBZRHwXJdVmiAdrJB";

	ТелоЗапроса = СформироватьТелоЗапроса(ПлатёжныйКалендарь);

	ОтветJSON = Ждать ВыполнитьЗапросКMistral(ТелоЗапроса, APIКлюч);

	Если ОтветJSON = Неопределено Тогда
		Возврат "";
	КонецЕсли;

	Попытка
		Описание = ОтветJSON.choices[0].message.content;
	Исключение
		Описание = "";
	КонецПопытки;

	Возврат Описание;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Асинх Функция ВыполнитьЗапросКMistral(ТелоJSON, APIКлюч)

	Соединение = Новый HTTPСоединение("api.mistral.ai", 443, , , , 30, Новый ЗащищенноеСоединениеOpenSSL);

	Запрос = Новый HTTPЗапрос("/v1/chat/completions");
	Запрос.УстановитьТелоИзСтроки(ТелоJSON, "UTF-8");

	Запрос.Заголовки.Вставить("Content-Type", "application/json");
	Запрос.Заголовки.Вставить("Authorization", "Bearer " + APIКлюч);

	Ожидание = Соединение.ВызватьHTTPМетодАсинх("POST", Запрос);

	Попытка
		HTTPОтвет = Ждать Ожидание;
	Исключение
		ТекстОшибки = НСтр("ru = 'Ответ от Mistral не получен'");
	КонецПопытки;

	Если HTTPОтвет.КодСостояния <> 200 Тогда
		Возврат Неопределено;
	КонецЕсли;

	СтрокаОтвета = HTTPОтвет.ПолучитьТелоКакСтроку();

	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(СтрокаОтвета);

	Возврат ПрочитатьJSON(ЧтениеJSON);

КонецФункции

////////////////////////////////////////////////////////////////////////////////
// Формирование JSON запроса
////////////////////////////////////////////////////////////////////////////////

Функция СформироватьТелоЗапроса(ПлатёжныйКалендарь)

	ЗапросСтруктура = Новый Структура;
	ЗапросСтруктура.Вставить("model", "mistral-small-latest");

	Сообщения = Новый Массив;

	СистемноеСообщение = Новый Структура;
	СистемноеСообщение.Вставить("role", "system");
	СистемноеСообщение.Вставить("content",
"Ты финансовый помощник. Анализируй планируемые денежные операции организации и давай краткие рекомендации по управлению денежными средствами. Если прогнозируется отрицательный остаток по счету, предложи способы избежать кассового разрыва. Отвечай профессионально, кратко и на русском языке.");
	ПользовательСообщение = Новый Структура;
	ПользовательСообщение.Вставить("role", "user");
	ПользовательСообщение.Вставить("content", "Напиши аналитику на данный платёжный календарь: " + ПлатёжныйКалендарь);

	Сообщения.Добавить(СистемноеСообщение);
	Сообщения.Добавить(ПользовательСообщение);

	ЗапросСтруктура.Вставить("messages", Сообщения);
	ЗапросСтруктура.Вставить("temperature", 0.7);

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, ЗапросСтруктура);

	Возврат ЗаписьJSON.Закрыть();
	
КонецФункции

#КонецОбласти